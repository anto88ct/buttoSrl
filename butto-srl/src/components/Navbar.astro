---
import LanguageSwitch from './LanguageSwitch.astro';
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

const navLinks = [
  { label: 'Home',           href: '/',               key: 'nav.home' },
  { label: 'Chi Siamo',      href: '/chi-siamo',      key: 'nav.chiSiamo' },
  { label: 'Servizi',        href: '/servizi',         key: 'nav.servizi' },
  { label: 'Sostenibilità',  href: '/sostenibilita',   key: 'nav.sostenibilita' },
  { label: 'Certificazioni', href: '/certificazioni',  key: 'nav.certificazioni' },
  { label: 'News',           href: '/news',            key: 'nav.news' },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 w-full z-50 bg-forest/95 backdrop-blur-xl border-b border-white/5 transition-all duration-300">
  <nav class="flex items-center justify-between px-6 lg:px-12 py-4 max-w-screen-2xl mx-auto">

    <!-- Brand -->
    <a href="/" class="flex items-center gap-3 group shrink-0" aria-label="Buttò S.r.l.">
      <Image
        src={logo}
        alt="Buttò S.r.l."
        class="h-14 md:h-16 w-auto object-contain transition-transform duration-300 group-hover:scale-105"
        width={200}
        loading="eager"
        fetchpriority="high"
      />
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-0.5">
      {navLinks.map(({ label, href, key }) => {
        const active = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        return (
          <a
            href={href}
            data-i18n={key}
            class={`relative px-5 py-2.5 font-condensed font-600 text-sm tracking-[0.08em] uppercase transition-all duration-200 ${
              active ? 'text-ochre' : 'text-ivory/55 hover:text-ivory'
            }`}
          >
            {label}
            {active && <span class="absolute bottom-1.5 left-1/2 -translate-x-1/2 w-4 h-px bg-ochre"></span>}
          </a>
        );
      })}
    </div>

    <!-- Language switch + CTA + hamburger -->
    <div class="flex items-center gap-3 shrink-0">
      <!-- Language switch (desktop) -->
      <div class="hidden md:flex">
        <LanguageSwitch />
      </div>
      <a
        href="/contatti"
        data-i18n="nav.contattaci"
        class="hidden sm:inline-flex items-center gap-2 btn-primary"
      >
        <i class="fa-solid fa-envelope text-[11px]"></i>
        Contattaci
      </a>
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2.5 text-ivory hover:text-ochre transition-colors"
        aria-label="Menu"
      >
        <svg id="icon-bars" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden border-t border-white/5 bg-forest/98 overflow-hidden">
    <div class="flex flex-col p-5 gap-1 max-w-screen-2xl mx-auto">
      {navLinks.map(({ label, href, key }) => {
        const active = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        return (
          <a
            href={href}
            data-i18n={key}
            class={`px-4 py-3 font-condensed font-600 text-sm tracking-[0.08em] uppercase transition-colors ${
              active ? 'text-ochre' : 'text-ivory/55 hover:text-ivory'
            }`}
          >
            {label}
          </a>
        );
      })}
      <!-- Language switch (mobile) -->
      <div class="px-4 py-3 flex items-center gap-3">
        <span class="font-condensed text-xs text-ivory/30 uppercase tracking-widest">Lingua</span>
        <LanguageSwitch />
      </div>
      <a
        href="/contatti"
        data-i18n="nav.contattaci"
        class="mt-3 flex items-center justify-center gap-2 btn-primary text-center"
      >
        <i class="fa-solid fa-envelope text-[11px]"></i>
        Contattaci
      </a>
    </div>
  </div>
</header>
