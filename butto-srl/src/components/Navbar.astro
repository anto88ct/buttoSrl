---
const navLinks = [
  { label: 'Home',          href: '/' },
  { label: 'Chi Siamo',     href: '/chi-siamo' },
  { label: 'Servizi',       href: '/servizi' },
  { label: 'Sostenibilità', href: '/sostenibilita' },
  { label: 'Certificazioni',href: '/certificazioni' },
  { label: 'News',          href: '/news' },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 w-full z-50 bg-forest/95 backdrop-blur-xl border-b border-white/5 transition-all duration-300">
  <nav class="flex items-center justify-between px-6 lg:px-12 py-4 max-w-screen-2xl mx-auto">

    <!-- Brand -->
    <a href="/" class="flex items-center gap-3 group shrink-0" aria-label="Buttò S.r.l.">
      <img 
        src="/logo.png" 
        alt="Buttò S.r.l." 
        class="h-10 md:h-12 w-auto object-contain transition-transform duration-300 group-hover:scale-105"
      />
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-0.5">
      {navLinks.map(({ label, href }) => {
        const active = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        return (
          <a
            href={href}
            class={`relative px-5 py-2.5 font-condensed font-600 text-sm tracking-[0.08em] uppercase transition-all duration-200 ${
              active ? 'text-ochre' : 'text-ivory/55 hover:text-ivory'
            }`}
          >
            {label}
            {active && <span class="absolute bottom-1.5 left-1/2 -translate-x-1/2 w-4 h-px bg-ochre"></span>}
          </a>
        );
      })}
    </div>

    <!-- CTA + hamburger -->
    <div class="flex items-center gap-4 shrink-0">
      <a
        href="/contatti"
        class="hidden sm:inline-flex items-center gap-2 btn-primary"
      >
        <i class="fa-solid fa-envelope text-[11px]"></i>
        Contattaci
      </a>
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2.5 text-ivory/60 hover:text-ivory transition-colors"
        aria-label="Menu"
      >
        <i id="icon-bars"  class="fa-solid fa-bars text-lg"></i>
        <i id="icon-close" class="fa-solid fa-xmark text-lg hidden"></i>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden border-t border-white/5 bg-forest/98 overflow-hidden">
    <div class="flex flex-col p-5 gap-1 max-w-screen-2xl mx-auto">
      {navLinks.map(({ label, href }) => {
        const active = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        return (
          <a
            href={href}
            class={`px-4 py-3 font-condensed font-600 text-sm tracking-[0.08em] uppercase transition-colors ${
              active ? 'text-ochre' : 'text-ivory/55 hover:text-ivory'
            }`}
          >
            {label}
          </a>
        );
      })}
      <a
        href="/contatti"
        class="mt-3 flex items-center justify-center gap-2 btn-primary text-center"
      >
        <i class="fa-solid fa-envelope text-[11px]"></i>
        Contattaci
      </a>
    </div>
  </div>
</header>
