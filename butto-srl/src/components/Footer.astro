---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Chi Siamo", href: "/chi-siamo" },
  { label: "Servizi", href: "/servizi" },
  { label: "Sostenibilità", href: "/sostenibilita" },
  { label: "News", href: "/news" },
  { label: "Contatti", href: "/contatti" },
];
const docLinks = [
  { label: "Privacy Policy", href: "/privacy" },
  { label: "Cookie Policy", href: "/cookie" },
  { label: "Certificazioni & Rifiuti", href: "/certificazioni" },
];
---

<footer class="bg-forest grain relative overflow-hidden">
  <!-- Top accent line -->
  <div
    class="h-px bg-gradient-to-r from-transparent via-ochre/40 to-transparent"
  >
  </div>

  <!-- Giant background watermark -->
  <div
    class="absolute bottom-0 right-0 pointer-events-none select-none overflow-hidden"
  >
    <span
      class="font-condensed font-800 text-[22vw] text-ivory/[0.1] leading-none tracking-tighter"
    >
      1978
    </span>
  </div>

  <div class="max-w-screen-2xl mx-auto px-6 lg:px-12 pt-20 pb-12 relative z-10">
    <!-- Top row -->
    <div
      class="grid grid-cols-1 lg:grid-cols-12 gap-16 pb-16 border-b border-white/8"
    >
      <!-- Brand column -->
      <div class="lg:col-span-4 space-y-6">
        <a href="/" class="flex items-center gap-3 group">
          <Image
            src={logo}
            alt="Buttò S.r.l."
            class="h-12 md:h-14 w-auto object-contain transition-transform duration-300 group-hover:scale-105"
            width={200}
            loading="lazy"
          />
        </a>

        <p
          data-i18n="footer.descrizione"
          class="font-body text-ivory/40 text-sm leading-relaxed max-w-xs"
        >
          Dal 1978, custodi dell'ambiente siciliano. Leader nella gestione
          integrata dei rifiuti e servizi pubblici.
        </p>

        <!-- Certifications -->
        <div class="flex flex-wrap gap-2">
          {
            ["ISO 14001", "ISO 9001", "Albo Gestori"].map((c) => (
              <span class="font-condensed text-[0.6rem] font-700 uppercase tracking-[0.18em] px-3 py-1.5 border border-white/10 text-ivory/35">
                {c}
              </span>
            ))
          }
        </div>

        <!-- Social -->
        <!-- <div class="flex items-center gap-3 pt-2">
          <span data-i18n="footer.seguici" class="overline text-ivory/20 mr-1">Seguici</span>
          <a
            href="#"
            aria-label="LinkedIn"
            class="w-9 h-9 border border-white/10 flex items-center justify-center text-ivory/35 hover:text-ochre hover:border-ochre/40 transition-all duration-200"
          >
            <i class="fa-brands fa-linkedin text-sm"></i>
          </a>
          <a
            href="#"
            aria-label="Feed RSS"
            class="w-9 h-9 border border-white/10 flex items-center justify-center text-ivory/35 hover:text-ochre hover:border-ochre/40 transition-all duration-200"
          >
            <i class="fa-solid fa-rss text-sm"></i>
          </a>
        </div> -->
      </div>

      <!-- Navigation -->
      <div class="lg:col-span-2">
        <p data-i18n="footer.navigazione" class="overline text-ivory/25 mb-7">
          Navigazione
        </p>
        <ul class="space-y-3">
          {
            navLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="font-body text-ivory/45 hover:text-ivory text-sm transition-colors duration-200 link-line"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Documents -->
      <div class="lg:col-span-2">
        <p data-i18n="footer.documenti" class="overline text-ivory/25 mb-7">
          Documenti
        </p>
        <ul class="space-y-3">
          {
            docLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="font-body text-ivory/45 hover:text-ivory text-sm transition-colors duration-200 link-line"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div class="lg:col-span-4">
        <p data-i18n="footer.contatti" class="overline text-ivory/25 mb-7">
          Contatti
        </p>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <i
              class="fa-solid fa-location-dot text-ochre/50 text-sm mt-0.5 shrink-0 w-4"
            ></i>
            <span class="text-ivory/45 text-sm leading-snug">
              Via S. Giuseppe N°42, Assoro (EN), Sicilia
            </span>
          </li>
          <li class="flex items-start gap-3">
            <i
              class="fa-solid fa-phone text-ochre/50 text-sm mt-0.5 shrink-0 w-4"
            ></i>
            <span class="text-ivory/45 text-sm">+39 375 927 8085</span>
          </li>
          <li class="flex items-start gap-3">
            <i
              class="fa-solid fa-envelope text-ochre/50 text-sm mt-0.5 shrink-0 w-4"
            ></i>
            <a
              href="mailto:servizi.butto@gmail.com"
              class="text-ivory/45 hover:text-ochre text-sm transition-colors"
            >
              servizi.butto@gmail.com
            </a>
          </li>
          <li class="flex items-start gap-3">
            <i
              class="fa-solid fa-envelope-open-text text-ochre/50 text-sm mt-0.5 shrink-0 w-4"
            ></i>
            <a
              href="mailto:impresabutto@pec.it"
              class="text-ivory/45 hover:text-ochre text-sm transition-colors"
            >
              impresabutto@pec.it
            </a>
          </li>

          <!-- Emergency card -->
          <!-- <li class="mt-6 p-5 border border-ochre/20 bg-ochre/5">
            <p class="overline text-ochre/60 mb-2">
              <i class="fa-solid fa-triangle-exclamation mr-1.5"></i>
              <span data-i18n="footer.emergenze">Emergenze 24/7</span>
            </p>
            <p class="font-display text-ivory text-2xl">
              800 <span class="text-ochre">— — — —</span>
            </p>
          </li> -->
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="pt-8 flex flex-col items-center gap-6 text-center md:flex-row md:text-left md:justify-between md:items-end border-t border-white/5"
    >
      <div class="flex flex-col gap-2">
        <span
          class="font-condensed text-[0.7rem] text-ivory/40 tracking-[0.1em] uppercase"
        >
          © {new Date().getFullYear()} Buttò Carmelo S.r.l.
        </span>
        <span
          class="font-body text-[0.65rem] text-ivory/25 leading-relaxed max-w-3xl"
        >
          Sede Legale: Via San Giuseppe 42, 94010 Assoro (EN) | P.IVA e C.F.: 01208350866<br />
          Capitale Sociale: € 10.000,00 i.v. | Ufficio del Registro delle Imprese di Enna | REA: EN-68443<br />
          PEC: <a href="mailto:&#105;&#109;&#112;&#114;&#101;&#115;&#97;&#98;&#117;&#116;&#116;&#111;&#64;&#112;&#101;&#99;&#46;&#105;&#116;" class="hover:text-ochre transition-colors">&#105;&#109;&#112;&#114;&#101;&#115;&#97;&#98;&#117;&#116;&#116;&#111;&#64;&#112;&#101;&#99;&#46;&#105;&#116;</a>
        </span>
      </div>
      <span
        data-i18n="footer.tagline"
        class="font-condensed text-[0.62rem] text-ivory/15 tracking-[0.2em] uppercase shrink-0"
      >
        Custodi dell'Ambiente dal 1978
      </span>
    </div>
  </div>
</footer>
