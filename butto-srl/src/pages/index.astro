---
import Layout from '../layouts/Layout.astro';
import GoogleBusiness from '../components/GoogleBusiness.astro';
import { Image } from 'astro:assets';
import leafeHeart from '../assets/leafe-heart.jpg';
import clientLogo1 from '../assets/clienti/2018.jpeg';
import clientLogo2 from '../assets/clienti/Autogrill-logo-cuadrado.png';
import clientLogo3 from '../assets/clienti/Decathlon-Logo.png';
import clientLogo4 from '../assets/clienti/images.png';
import clientLogo5 from '../assets/clienti/logoDesk.png';
import clientLogo6 from '../assets/clienti/logo-gruppoarena-60e7224024a4b.jpeg';

const clientLogos = [
  { src: clientLogo1, big: true },
  { src: clientLogo2, big: true },
  { src: clientLogo3 },
  { src: clientLogo4 },
  { src: clientLogo5 },
  { src: clientLogo6 },
];

const services = [
  { num: '01', icon: 'fa-recycle',      title: 'Gestione Rifiuti',      desc: 'Trasporto e smaltimento certificato con tracciabilità digitale e piena conformità normativa.',   href: '/servizi#gestione-rifiuti' },
  { num: '02', icon: 'fa-broom',        title: 'Pulizie Enti Pubblici',  desc: 'Sanificazione di sedi istituzionali, scuole e ospedali con protocolli a impatto minimo.',       href: '/servizi#pulizie-pubbliche' },
  { num: '03', icon: 'fa-tree',         title: 'Verde Urbano',           desc: 'Manutenzione di parchi, giardini pubblici e aree verdi per il decoro dei comuni siciliani.',    href: '/servizi#verde-urbano' },
  { num: '04', icon: 'fa-biohazard',     title: 'Smaltimento Rifiuti Speciali', desc: 'Trasporto e smaltimento certificato di rifiuti speciali e pericolosi con tracciabilità digitale completa.', href: '/servizi#smaltimento-rifiuti-speciali' },
];

const ticker = [
  '— ISO 14001:2015',
  '— Albo Gestori Ambientali',
  '— ISO 9001:2015',
  '— 120+ Comuni Serviti',
  '— Dal 1978 ad Assoro (EN)',
  '— Zero Waste Strategy',
  '— Flotta a Basse Emissioni',
];

---

<Layout
  title="Home"
  description="Buttò S.r.l. – Dal 1978 leader nella gestione integrata dei servizi ambientali ad Assoro (EN). Smaltimento rifiuti, appalti pubblici di pulizia, sostenibilità."
>

  <!-- ══════════════════════ HERO ══════════════════════ -->
  <section class="relative h-screen flex items-center overflow-hidden">

    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay muted loop playsinline preload="none"
      poster="/og-default.jpg"
    >
      <source src="/video.mp4" type="video/mp4" />
    </video>

    <div class="absolute inset-0 bg-forest/75"></div>
    <div class="absolute inset-0 grain pointer-events-none"></div>

    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-1/3 w-px h-full bg-gradient-to-b from-ochre/20 via-ochre/5 to-transparent"></div>
      <div class="absolute top-0 right-1/4 w-px h-2/3 bg-gradient-to-b from-white/5 to-transparent"></div>
    </div>

    <div class="max-w-screen-2xl mx-auto px-6 lg:px-14 w-full -mt-16 pb-6 relative z-10">
      <div class="flex flex-col items-start text-left gap-3 max-w-4xl">
        <div class="reveal">
          <span data-i18n="home.hero.eyebrow" class="overline text-ochre tracking-[0.28em]">
            <i class="fa-solid fa-circle-dot text-[6px] align-middle mr-2"></i>
            Assoro · Sicilia · Dal 1978
          </span>
        </div>

        <div class="space-y-1 reveal delay-1">
          <h1 class="display-xl text-ivory text-5xl md:text-7xl lg:text-8xl leading-[1.02]">
            <span data-i18n="home.hero.h1l1" class="block">Soluzioni Concrete</span>
            <span data-i18n-html="home.hero.h1l2html" class="block italic">per l'<span class="text-sage">Ambiente</span> e il Territorio.</span>
          </h1>
        </div>

        <p data-i18n="home.hero.body" class="font-body text-ivory/50 text-base leading-relaxed max-w-lg reveal delay-2">
          Da Assoro, operiamo in tutta la Sicilia offrendo soluzioni certificate per lo smaltimento dei rifiuti, la manutenzione del verde urbano e l'igiene pubblica. Partner affidabile per il decoro e la sostenibilità del territorio.
        </p>

        <div class="flex flex-wrap justify-start gap-4 reveal delay-3">
          <a href="/servizi" class="btn-primary text-base px-8 py-4">
            <span data-i18n="home.hero.cta1">I Nostri Servizi</span> <i class="fa-solid fa-arrow-right text-[10px]"></i>
          </a>
          <a href="/chi-siamo" class="btn-ghost-dark text-base px-8 py-4">
            <span data-i18n="home.hero.cta2">La Nostra Storia</span>
          </a>
        </div>

        <div class="flex flex-wrap justify-start gap-6 pt-3 border-t border-white/8 reveal delay-4">
          {[
            { icon: 'fa-certificate', text: 'ISO 14001' },
            { icon: 'fa-shield-halved', text: 'Albo Gestori' },
            { icon: 'fa-truck', text: 'Flotta ECO' },
          ].map(({ icon, text }) => (
            <span class="flex items-center gap-2 font-condensed font-600 text-[0.7rem] text-ivory/35 uppercase tracking-[0.12em]">
              <i class={`fa-solid ${icon} text-ochre/60 text-xs`}></i>
              {text}
            </span>
          ))}
        </div>
      </div>
    </div>

    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 reveal delay-5">
      <span data-i18n="home.hero.scroll" class="overline text-ivory/20 text-[0.6rem]">Scorri</span>
      <div class="w-px h-12 bg-gradient-to-b from-ochre/40 to-transparent animate-scan"></div>
    </div>
  </section>

  <!-- ══════════════════════ TICKER ══════════════════════ -->
  <div class="bg-ochre py-3.5 overflow-hidden">
    <div class="marquee-track">
      {[...ticker, ...ticker].map(item => (
        <span class="font-condensed font-700 text-[0.75rem] uppercase tracking-[0.2em] text-forest whitespace-nowrap px-10">
          {item}
        </span>
      ))}
    </div>
  </div>

  <!-- ══════════════════════ STATS ══════════════════════ -->
  <section class="py-24 bg-ivory dot-grid">
    <div class="max-w-screen-2xl mx-auto px-6 lg:px-14">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-0 border border-linen">
        {[
          { count: '45',   suffix: '+', lKey: 'home.stats.anni',       sKey: 'home.stats.anniSub',      label: 'Anni',    sub: 'di esperienza sul campo' },
          { count: '120',  suffix: '+', lKey: 'home.stats.comuni',      sKey: 'home.stats.comuniSub',    label: 'Comuni',  sub: 'serviti in Sicilia' },
          { count: '4200', suffix: '',  lKey: 'home.stats.co2Label',    sKey: 'home.stats.co2Sub',       label: 'Ton CO₂', sub: 'risparmiate ogni anno' },
          { count: '85',   suffix: '%', lKey: 'home.stats.rifiutiLabel',sKey: 'home.stats.rifiutiSub',   label: 'Rifiuti', sub: 'recuperati e riciclati' },
        ].map(({ count, suffix, lKey, sKey, label, sub }, i) => (
          <div class={`p-10 lg:p-14 text-center ${i < 3 ? 'border-r border-linen' : ''} ${i >= 2 ? 'border-t lg:border-t-0 border-linen' : ''} reveal delay-${i + 1}`}>
            <p class="stat-xl text-ochre mb-1">
              <span data-count={count + suffix}>{count}{suffix}</span>
            </p>
            <p data-i18n={lKey} class="font-condensed font-700 text-ink text-base uppercase tracking-[0.12em]">{label}</p>
            <p data-i18n={sKey} class="font-body text-muted text-xs mt-1">{sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════ SERVICES / CUSTODI ══════════════════════ -->
  <section id="custodi" class="relative bg-white pt-16 pb-20">

    <!-- Overline + Titolo centrati -->
    <div class="text-center mb-8 reveal max-w-screen-2xl mx-auto px-6 lg:px-14">
      <span data-i18n="home.services.eyebrow" class="overline text-ochre">I Nostri Servizi</span>
      <div class="rule-ochre mx-auto"></div>
      <h2 data-i18n-html="home.services.h2" class="display-lg text-ink mt-5">
        Custodi del<br/>
        <em class="text-forest-soft not-italic">Bene Comune</em>
      </h2>
      <a href="/servizi" class="inline-flex mt-5 font-condensed font-700 text-[0.75rem] uppercase tracking-[0.16em] text-ochre items-center gap-2 hover:gap-4 transition-all duration-300">
        <span data-i18n="home.services.viewAll">Vedi tutti i servizi</span> <i class="fa-solid fa-arrow-right"></i>
      </a>
    </div>

    <!-- Video globo: quasi full-width -->
    <div id="globe-wrapper" class="w-full h-[52vh] md:h-[70vh]">
      <video
        id="globe-video"
        src="/videos/world-spinning.mp4"
        autoplay
        loop
        muted
        playsinline
        class="w-full h-full object-contain"
      ></video>
    </div>

    <!-- Card animate: overlap il bordo inferiore del globo -->
    <div id="custodi-cards" class="-mt-24 md:-mt-32 relative z-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-6xl mx-auto px-6">
      {services.map(({ num, icon, href }, i) => (
        <a
          href={href}
          class="custodi-card group block h-full rounded-none outline-none focus-visible:ring-2 focus-visible:ring-ochre focus-visible:ring-offset-2 focus-visible:ring-offset-white"
        >
          <article
            class="relative h-full flex flex-col overflow-hidden bg-ivory border border-linen/80 group-hover:border-forest group-hover:bg-forest shadow-[0_8px_40px_rgba(22,44,27,0.08),0_2px_8px_rgba(22,44,27,0.05)] group-hover:shadow-[0_22px_60px_rgba(22,44,27,0.24)] transition-[background-color,border-color,box-shadow] duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
          >
            <!-- accent rule: precision/manifest wipe on hover -->
            <span aria-hidden="true" class="absolute inset-x-0 top-0 h-[3px] bg-ochre origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]"></span>

            <div class="flex flex-col gap-6 p-7 lg:p-9 h-full">
              <!-- ledger header: index N° + service mark, on a hairline -->
              <div class="flex items-center justify-between pb-5 border-b border-linen group-hover:border-ivory/15 transition-colors duration-500">
                <span class="font-condensed font-700 text-[0.72rem] uppercase tracking-[0.22em] text-muted group-hover:text-ochre transition-colors duration-500">N°&thinsp;{num}</span>
                <i class={`fa-solid ${icon} text-[1.05rem] text-ochre group-hover:text-ochre-light transition-colors duration-500`}></i>
              </div>

              <div class="space-y-3">
                <h3 data-i18n={`home.services.items.${i}.title`} class="font-serif text-2xl font-600 text-ink group-hover:text-ivory transition-colors duration-500 leading-tight text-balance">{services[i].title}</h3>
                <p data-i18n={`home.services.items.${i}.desc`} class="font-body text-ink/75 group-hover:text-ivory/65 text-sm leading-relaxed transition-colors duration-500 text-pretty">{services[i].desc}</p>
              </div>

              <div class="flex items-center gap-2 font-condensed font-700 text-[0.7rem] uppercase tracking-[0.16em] text-ochre group-hover:gap-4 transition-all duration-300 mt-auto pt-1">
                <span data-i18n="home.services.learnMore">Scopri di più</span> <i class="fa-solid fa-arrow-right text-[10px]"></i>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>

    <script is:inline>
      (function () {
        var LOOP_DURATION = 8;
        var CARD_DELAY_STEP = 0.5;

        function initCustodiAnimation() {
          var video = document.getElementById('globe-video');
          var cards = document.querySelectorAll('.custodi-card');

          if (!video || cards.length === 0) return;

          cards.forEach(function (card) {
            card.style.opacity = '0';
            card.style.transform = 'translateY(28px)';
            card.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
          });

          cards.forEach(function (card, i) {
            var triggerTime = CARD_DELAY_STEP * i;
            var revealed = false;
            var checkTime = function () {
              if (!revealed && video.currentTime >= triggerTime) {
                revealed = true;
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
                video.removeEventListener('timeupdate', checkTime);
              }
            };
            video.addEventListener('timeupdate', checkTime);
          });

          video.addEventListener('timeupdate', function () {
            var progress = (video.currentTime % LOOP_DURATION) / LOOP_DURATION;
            var scale = 1 + 0.025 * Math.sin(progress * Math.PI * 2);
            video.style.transform = 'scale(' + scale + ')';
          });
        }

        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              initCustodiAnimation();
              observer.disconnect();
            }
          });
        }, { threshold: 0.2 });

        var custodiSection = document.getElementById('custodi');
        if (custodiSection) observer.observe(custodiSection);
      })();
    </script>
  </section>

  <!-- ══════════════════════ CHI HA SCELTO BUTTÒ ══════════════════════ -->
  <section class="py-20 bg-white relative overflow-hidden border-b border-linen">
    <div class="max-w-screen-2xl mx-auto px-6 lg:px-14 mb-12 text-center reveal">
      <span data-i18n="home.trustedBy.eyebrow" class="overline text-ochre">Fiducia Consolidata</span>
      <div class="rule-ochre mx-auto"></div>
      <h2 data-i18n-html="home.trustedBy.h2html" class="display-sm text-ink mt-5">
        Chi ha scelto<br/>
        <em class="text-forest-soft not-italic">Buttò S.r.l.</em>
      </h2>
    </div>

    <div class="max-w-screen-2xl mx-auto px-6 lg:px-14">
      <div class="flex flex-wrap items-center justify-center gap-x-16 gap-y-10">
        {clientLogos.map(({ src, big }, i) => (
          <div class={`${big ? 'h-56 w-96' : 'h-32 w-56'} flex items-center justify-center reveal-scale delay-${(i % 5) + 1} transition-transform duration-500 hover:-translate-y-2 hover:scale-105`}>
            <Image src={src} alt="Logo cliente" class="max-h-full max-w-full object-contain" width={400} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════ FOUNDER ══════════════════════ -->
  <section class="py-28 bg-parchment relative overflow-hidden">
    <div class="max-w-screen-2xl mx-auto px-6 lg:px-14">
      <div class="grid lg:grid-cols-12 gap-16 items-center">

        <div class="lg:col-span-5 reveal-left">
          <div class="relative">
            <div class="img-zoom aspect-[3/4]">
              <Image src={leafeHeart} alt="Carmelo Buttò, fondatore" class="w-full h-full object-cover" loading="lazy" width={800} />
            </div>
            <div class="absolute top-6 left-6 bg-ochre text-forest px-4 py-2.5">
              <p data-i18n="home.founder.fondato" class="font-condensed font-800 text-xs uppercase tracking-[0.2em] text-forest/60">Fondato</p>
              <p class="font-display text-2xl leading-none">1978</p>
            </div>
            <div class="absolute -bottom-6 -right-4 bg-forest text-ivory p-6 max-w-[230px] grain">
              <p data-i18n="home.founder.quote" class="font-serif italic text-sm leading-relaxed text-ivory/80">
                "Un territorio pulito è il regalo più grande."
              </p>
              <p class="font-condensed text-[0.62rem] uppercase tracking-[0.18em] text-ochre mt-3">— Carmelo Buttò</p>
            </div>
          </div>
        </div>

        <div class="lg:col-span-7 lg:pl-8 space-y-8 reveal-right delay-1">
          <div>
            <span data-i18n="home.founder.eyebrow" class="overline text-ochre">La Nostra Storia</span>
            <div class="rule-ochre"></div>
            <h2 data-i18n-html="home.founder.h2html" class="display-lg text-ink mt-5">
              Un'eredità di cura<br/>
              <em class="text-forest-soft not-italic">per il territorio</em>
            </h2>
          </div>

          <div class="space-y-5 font-body text-muted leading-relaxed">
            <p data-i18n="home.founder.p1">
              Fondata da Carmelo Buttò ad Assoro, in provincia di Enna, la nostra azienda è cresciuta dal nucleo familiare fino a diventare un punto di riferimento nella gestione ambientale per la Sicilia centro-orientale.
            </p>
            <p data-i18n="home.founder.p2">
              Quattro decenni di esperienza ci hanno insegnato che prendersi cura dell'ambiente non è un servizio — è una vocazione che si tramanda di generazione in generazione.
            </p>
          </div>

          <div class="grid grid-cols-3 gap-0 border border-linen mt-8">
            {[
              { v: '45', suf: '+', lKey: 'home.founder.anni',   l: 'Anni' },
              { v: '120', suf: '+', lKey: 'home.founder.comuni', l: 'Comuni' },
              { v: '∞', suf: '',   lKey: 'home.founder.passione',l: 'Passione' },
            ].map(({ v, suf, lKey, l }, i) => (
              <div class={`p-6 text-center ${i < 2 ? 'border-r border-linen' : ''}`}>
                <p class="font-display text-3xl text-ink leading-none">{v}{suf}</p>
                <p data-i18n={lKey} class="font-condensed font-600 text-[0.65rem] uppercase tracking-[0.16em] text-muted mt-1.5">{l}</p>
              </div>
            ))}
          </div>

          <a href="/chi-siamo" class="btn-primary inline-flex">
            <span data-i18n="home.founder.cta">Scopri la nostra storia</span> <i class="fa-solid fa-arrow-right text-[10px]"></i>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════ SUSTAINABILITY BAND ══════════════════════ -->
  <section class="py-28 bg-forest grain relative overflow-hidden">

    <div class="absolute left-0 top-0 w-1 h-full bg-gradient-to-b from-ochre/60 via-ochre/20 to-transparent"></div>

    <div class="max-w-screen-2xl mx-auto px-6 lg:px-14">
      <div class="grid lg:grid-cols-12 gap-14 items-start">

        <div class="lg:col-span-5 space-y-8 reveal">
          <div>
            <span data-i18n="home.sustainability.eyebrow" class="overline text-ochre">Eco-Responsabilità</span>
            <div class="rule-ochre"></div>
            <h2 data-i18n-html="home.sustainability.h2html" class="display-lg text-ivory mt-5">
              Numeri che<br/>
              <em class="text-sage not-italic">Respirano.</em>
            </h2>
          </div>
          <p data-i18n="home.sustainability.body" class="font-body text-ivory/45 leading-relaxed">
            L'impatto tangibile delle nostre operazioni ambientali, anno dopo anno, comunità per comunità.
          </p>
          <a href="/sostenibilita" class="btn-ghost-dark inline-flex">
            <span data-i18n="home.sustainability.cta">Il nostro impegno</span> <i class="fa-solid fa-arrow-right text-[10px]"></i>
          </a>
        </div>

        <div class="lg:col-span-7 reveal-right delay-1">
          <div class="grid grid-cols-2 gap-px bg-white/8">

            <div class="col-span-2 bg-forest-mid p-10 group hover:bg-forest-soft transition-colors duration-300">
              <div class="flex items-start justify-between mb-6">
                <i class="fa-solid fa-leaf text-sage text-2xl"></i>
                <span data-i18n="home.sustainability.annoPer" class="overline text-ivory/25">Anno su Anno</span>
              </div>
              <p class="stat-xl text-ivory mb-2">
                <span data-count="4200">4.200</span>
              </p>
              <p data-i18n="home.sustainability.co2Sub" class="font-condensed font-700 text-ivory/40 text-sm uppercase tracking-[0.18em]">Tonnellate CO₂ Risparmiate</p>
              <p data-i18n="home.sustainability.co2Note" class="font-body text-ivory/25 text-xs mt-4 pt-4 border-t border-white/8">
                Equivalente a 120.000 alberi piantati ogni anno
              </p>
            </div>

            <div class="bg-ochre p-10">
              <i class="fa-solid fa-recycle text-forest text-2xl mb-6 block"></i>
              <p class="stat-xl text-forest leading-none mb-2">
                <span data-count="85%">85%</span>
              </p>
              <p data-i18n="home.sustainability.rifiutiLabel" class="font-condensed font-700 text-forest/60 text-xs uppercase tracking-[0.18em]">Rifiuti Recuperati</p>
            </div>

            <div class="bg-forest-mid p-10 group hover:bg-forest-soft transition-colors">
              <i class="fa-solid fa-city text-sage/50 text-2xl mb-6 block"></i>
              <p class="stat-xl text-ivory leading-none mb-2">
                <span data-count="120+">120+</span>
              </p>
              <p data-i18n="home.sustainability.comuniLabel" class="font-condensed font-700 text-ivory/40 text-xs uppercase tracking-[0.18em]">Comuni Serviti</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════ RECENSIONI GOOGLE ══════════════════════ -->
  <GoogleBusiness />

  <!-- ══════════════════════ FINAL CTA ══════════════════════ -->
  <section class="py-28 bg-forest grain relative overflow-hidden">

    <div class="absolute right-0 bottom-0 pointer-events-none select-none">
      <span class="font-condensed font-800 text-[20vw] text-ivory/[0.1] leading-none tracking-tighter">TALK</span>
    </div>

    <div class="absolute top-12 right-12 w-32 h-32 border border-ochre/10 rotate-45 pointer-events-none"></div>
    <div class="absolute top-20 right-20 w-16 h-16 border border-ochre/15 rotate-45 pointer-events-none"></div>

    <div class="max-w-screen-2xl mx-auto px-6 lg:px-14 relative z-10">
      <div class="max-w-2xl mx-auto reveal">
        <span data-i18n="home.cta.eyebrow" class="overline text-ochre">Parliamo del tuo Territorio</span>
        <div class="rule-ochre"></div>
        <h2 data-i18n-html="home.cta.h2html" class="display-lg text-ivory mt-5 mb-6">
          Costruiamo insieme<br/>
          <em class="text-sage not-italic">la soluzione su misura</em>
        </h2>
        <p data-i18n="home.cta.body" class="font-body text-ivory/40 text-lg leading-relaxed mb-12 max-w-xl">
          Ente pubblico o azienda privata: il nostro team è pronto ad ascoltarti e progettare il servizio ambientale più adatto alla tua realtà.
        </p>
        <div class="flex flex-wrap gap-5">
          <a href="/contatti" class="btn-primary text-base px-10 py-5">
            <span data-i18n="home.cta.cta1">Contattaci Ora</span> <i class="fa-solid fa-envelope text-[11px]"></i>
          </a>
          <a href="/servizi" class="btn-ghost-dark text-base px-10 py-5">
