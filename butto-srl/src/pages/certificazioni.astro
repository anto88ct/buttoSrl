        </p>
      </div>
    </div>

    <!-- ── PINNED SCROLL SEQUENCE (desktop) ──────────────────────── -->
    <div
      id="mc-wrap"
      class="relative hidden lg:block"
      style={`height: calc(100vh + ${macrocategorie.length} * 72vh)`}
    >
      <div class="mc-sticky sticky top-0 h-screen flex items-center overflow-hidden">
        <div class="max-w-screen-2xl mx-auto w-full px-6 lg:px-14">
          <div class="grid grid-cols-12 gap-16 items-center">

            <!-- Locked material card -->
            <div class="col-span-5">
              <div class="aspect-[4/5] max-h-[68vh] bg-forest relative overflow-hidden shadow-forest">
                <div
                  id="mc-bg"
                  data-img={macrocategorie[0].img}
                  class="absolute inset-0 bg-cover bg-center"
                  style={`background-image:url(${macrocategorie[0].img})`}
                ></div>
                <div class="absolute inset-0 bg-forest/80 mix-blend-multiply"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-forest via-forest/30 to-forest/60"></div>

                <div class="absolute top-8 left-8 right-8 flex items-center justify-between z-10">
                  <span id="mc-code" class="inline-block px-2.5 py-1 bg-ivory/10 border border-ochre/30 text-ochre text-xs font-condensed tracking-wider backdrop-blur-sm">
                    CER {macrocategorie[0].code}
                  </span>
                  <span id="mc-counter" class="font-condensed text-ivory/40 text-xs tracking-[0.24em]">
                    01 / {String(macrocategorie.length).padStart(2, '0')}
                  </span>
                </div>
                <div class="absolute inset-0 flex items-center justify-center z-10">
                  <i id="mc-icon" data-icon={macrocategorie[0].icon} class={`fa-solid ${macrocategorie[0].icon} text-ochre/85 text-[9rem] drop-shadow-[0_8px_24px_rgba(14,12,9,0.55)]`}></i>
                </div>
                <div class="absolute bottom-8 left-8 right-8 z-10">
                  <div class="rule-ochre mb-4"></div>
                  <h3 id="mc-title" class="font-serif italic text-4xl text-ivory">{macrocategorie[0].title}</h3>
                </div>
              </div>
            </div>

            <!-- Vertical stepper -->
            <ol class="col-span-7 flex flex-col gap-1">
              {macrocategorie.map(({ icon, title, code, img, desc }, i) => (
                <li
                  class="mc-step group flex items-stretch gap-6"
                  data-index={i}
                  data-icon={icon}
                  data-code={code}
                  data-title={title}
                  data-img={img}
                  data-active={i === 0 ? 'true' : 'false'}
                  data-passed="false"
                >
                  <div class="flex flex-col items-center shrink-0">
                    <span class="w-11 h-11 rounded-full border-2 border-linen text-muted flex items-center justify-center font-condensed font-700 text-sm transition-all duration-500 group-data-[active=true]:border-ochre group-data-[active=true]:bg-ochre group-data-[active=true]:text-ivory group-data-[active=true]:scale-110 group-data-[passed=true]:border-ochre group-data-[passed=true]:text-ochre">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    {i < macrocategorie.length - 1 && (
                      <span class="w-px flex-1 my-2 bg-linen relative overflow-hidden">
                        <span class="absolute inset-0 bg-ochre origin-top scale-y-0 group-data-[passed=true]:scale-y-100 transition-transform duration-500"></span>
                      </span>
                    )}
                  </div>

                  <div class="flex-1 py-1 group-data-[active=true]:py-3 transition-all duration-500">
                    <h3
                      data-i18n={`certificazioni.macrocategorie.items.${i}.title`}
                      class="font-serif italic leading-tight text-2xl text-ink/30 group-data-[active=true]:text-ink group-data-[active=true]:text-[2.4rem] transition-all duration-500"
                    >
                      {title}
                    </h3>
                    <div class="grid grid-rows-[0fr] group-data-[active=true]:grid-rows-[1fr] transition-[grid-template-rows] duration-500 ease-out">
                      <div class="overflow-hidden">
                        <p
                          data-i18n={`certificazioni.macrocategorie.items.${i}.desc`}
                          class="font-body text-lg text-ink/70 leading-relaxed mt-3 opacity-0 group-data-[active=true]:opacity-100 transition-opacity duration-500 delay-100 max-w-xl"
                        >
                          {desc}
                        </p>
                      </div>
                    </div>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </div>

    <!-- ── MOBILE STACKED (no pin) ───────────────────────────────── -->
    <div id="mc-stack" class="lg:hidden max-w-screen-2xl mx-auto px-6 lg:px-14 mt-12 flex flex-col">
      {macrocategorie.map(({ icon, title, code, img, desc }, i) => (
        <div class="flex items-start gap-5 py-8 reveal" data-index={i}>
          <div class="flex flex-col items-center shrink-0 self-stretch">
            <span
              class="w-14 h-14 rounded-full relative overflow-hidden flex items-center justify-center bg-cover bg-center shadow-forest"
              style={`background-image:url(${img})`}
            >
              <span class="absolute inset-0 bg-forest/80 mix-blend-multiply"></span>
              <i class={`fa-solid ${icon} relative z-10 text-ochre/90 text-base`}></i>
            </span>
            {i < macrocategorie.length - 1 && (
              <span class="w-px flex-1 mt-3 bg-linen"></span>
            )}
          </div>
          <div class="flex-1">
            <span class="inline-block px-2 py-0.5 bg-linen text-ink text-[11px] font-condensed tracking-wider mb-2">CER {code}</span>
            <h3 data-i18n={`certificazioni.macrocategorie.items.${i}.title`} class="font-serif italic text-2xl text-ink leading-tight">{title}</h3>
            <p data-i18n={`certificazioni.macrocategorie.items.${i}.desc`} class="font-body text-base text-muted mt-2 leading-relaxed">{desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="max-w-screen-2xl mx-auto px-6 lg:px-14 pb-24">
      <div class="mt-12 bg-parchment p-6 border border-linen text-center reveal">
        <p class="font-body text-ink text-sm">
          <i class="fa-solid fa-circle-check text-ochre mr-2"></i>
          <span data-i18n-html="certificazioni.macrocategorie.note">Siamo inoltre autorizzati alla gestione di <strong>Rifiuti Spiaggiati (CER 20.01.99)</strong> e <strong>Rifiuti Cimiteriali (CER 20.03.99)</strong>.</span>
        </p>
      </div>
    </div>
  </section>

  <script>
    const wrap = document.getElementById('mc-wrap');
    const steps = Array.from(document.querySelectorAll<HTMLElement>('.mc-step'));
    const cardBg = document.getElementById('mc-bg');
    const cardIcon = document.getElementById('mc-icon');
    const cardCode = document.getElementById('mc-code');
    const cardTitle = document.getElementById('mc-title');
    const cardCounter = document.getElementById('mc-counter');
    const total = steps.length;
    let current = -1;

    function setActive(index: number) {
      if (index === current) return;
      current = index;

      steps.forEach((el, i) => {
        el.dataset.active = i === index ? 'true' : 'false';
        el.dataset.passed = i < index ? 'true' : 'false';
      });

      const step = steps[index];
      if (!step || !cardIcon || !cardCode || !cardTitle || !cardCounter || !cardBg) return;

      const icon = step.dataset.icon!;
      cardIcon.classList.remove('icon-pop');
      void cardIcon.offsetWidth;
      cardIcon.className = `fa-solid ${icon} text-ochre/85 text-[9rem] drop-shadow-[0_8px_24px_rgba(14,12,9,0.55)] icon-pop`;
      cardIcon.dataset.icon = icon;

      const img = step.dataset.img!;
      if (cardBg.dataset.img !== img) {
        cardBg.classList.remove('bg-fade');
        void cardBg.offsetWidth;
        cardBg.style.backgroundImage = `url(${img})`;
        cardBg.dataset.img = img;
        cardBg.classList.add('bg-fade');
      }

      cardCode.textContent = `CER ${step.dataset.code}`;
      cardTitle.textContent = step.dataset.title ?? '';
      cardCounter.textContent = `${String(index + 1).padStart(2, '0')} / ${String(total).padStart(2, '0')}`;
    }

    if (wrap && steps.length && window.matchMedia('(min-width: 1024px)').matches) {
      function update() {
        const rect = wrap!.getBoundingClientRect();
        const usable = Math.max(1, wrap!.offsetHeight - window.innerHeight);
        // progress 0→1 across the pinned track
        const p = Math.min(Math.max(-rect.top / usable, 0), 1);
        const idx = Math.min(total - 1, Math.floor(p * total));
        setActive(idx);
      }

      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update, { passive: true });
      update();
    } else {
      setActive(0);
    }
  </script>

  <style>
    @keyframes icon-pop {
      from { opacity: 0; transform: scale(0.72) rotate(-6deg); }
      to   { opacity: 1; transform: scale(1) rotate(0deg); }
    }
    .icon-pop {
      animation: icon-pop 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @keyframes bg-fade {
      from { opacity: 0; transform: scale(1.06); }
      to   { opacity: 1; transform: scale(1); }
    }
    .bg-fade {
      animation: bg-fade 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @media (prefers-reduced-motion: reduce) {
      /* scroll-jack needs motion; fall back to the stacked list on every width */
      #mc-wrap { display: none !important; }
      #mc-stack { display: flex !important; }
      .icon-pop { animation: none; }
      .bg-fade { animation: none; }
    }
  </style>

