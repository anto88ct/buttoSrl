    <script type="application/json" id="cert-search-data" set:html={JSON.stringify(certSearchItems)} />
  </section>

  <script>
    const searchData = document.getElementById('cert-search-data');
    const searchItems: { label: string; tag: string; desc: string }[] = searchData
      ? JSON.parse(searchData.textContent || '[]')
      : [];
    const searchInput = document.getElementById('cert-search-input') as HTMLInputElement | null;
    const searchResults = document.getElementById('cert-search-results');
    const searchEmpty = document.getElementById('cert-search-empty');

    function normalize(s: string) {
      const NFD = s.toLowerCase().normalize('NFD');
      let out = '';
      for (const ch of NFD) {
        const code = ch.codePointAt(0) ?? 0;
        if (code < 0x0300 || code > 0x036f) out += ch;
      }
      return out;
    }

    function renderResults(query: string) {
      if (!searchResults || !searchEmpty) return;
      const q = normalize(query.trim());

      if (q.length < 2) {
        searchResults.classList.add('hidden');
        searchResults.classList.remove('flex');
        searchEmpty.classList.add('hidden');
        return;
      }

      const matches = searchItems
        .filter((it) => normalize(it.label).includes(q) || normalize(it.tag).includes(q) || normalize(it.desc).includes(q))
        .slice(0, 8);

      if (!matches.length) {
        searchResults.classList.add('hidden');
        searchResults.classList.remove('flex');
        searchEmpty.textContent = `Nessuna certificazione trovata per "${query.trim()}".`;
        searchEmpty.classList.remove('hidden');
        return;
      }

      searchEmpty.classList.add('hidden');
      searchResults.classList.remove('hidden');
      searchResults.classList.add('flex');
      searchResults.innerHTML = matches.map((it) => `
        <div class="flex items-start justify-between gap-4 px-5 py-4" role="option">
          <div>
            <h3 class="font-serif italic text-lg text-ivory">${it.label}</h3>
            <p class="font-body text-sm text-ivory/55 mt-1 leading-relaxed">${it.desc}</p>
          </div>
          <span class="shrink-0 inline-block px-2.5 py-1 bg-ivory/10 border border-ochre/30 text-ochre text-[11px] font-condensed tracking-wider">${it.tag}</span>
        </div>
      `).join('');
    }

    searchInput?.addEventListener('input', () => renderResults(searchInput.value));
  </script>

