          />
        </div>

        <div id="cert-search-results" class="hidden flex-col divide-y divide-white/8 bg-forest-mid border border-t-0 border-white/10" role="listbox" aria-label="Risultati ricerca"></div>
        <p id="cert-search-empty" class="hidden font-body text-ivory/50 text-sm mt-5 text-center"></p>
      </div>

      <div class="max-w-2xl mx-auto mt-14 pt-10 border-t border-white/8 text-center reveal delay-2">
        <a href="/contatti" class="btn-primary px-8 py-4 inline-flex">
          <i class="fa-solid fa-envelope text-[11px]"></i>
          <span>Non trovi la certificazione? Contattaci</span>
        </a>
      </div>
